rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function tripDocument(tripId) {
      return get(
        /databases/$(database)/documents/trips/$(tripId)
      );
    }

    function isMember(tripId) {
      return signedIn()
        && request.auth.uid
          in tripDocument(tripId).data.memberIds;
    }

    function isEditor(tripId) {
      return signedIn()
        && request.auth.uid
          in tripDocument(tripId).data.editorIds;
    }

    match /trips/{tripId} {
      allow create: if signedIn()
        && request.resource.data.ownerUserId
          == request.auth.uid
        && request.auth.uid
          in request.resource.data.memberIds;

      allow read: if signedIn()
        && request.auth.uid
          in resource.data.memberIds;

      allow update: if signedIn()
        && request.auth.uid
          in resource.data.editorIds
        && request.resource.data.ownerUserId
          == resource.data.ownerUserId;

      allow delete: if signedIn()
        && request.auth.uid
          == resource.data.ownerUserId;

      match /members/{memberId} {
        allow read: if isMember(tripId);
        allow write: if signedIn()
          && request.auth.uid
            == tripDocument(tripId)
              .data.ownerUserId;
      }

      match /{collectionName}/{documentId} {
        allow read: if isMember(tripId);
        allow create, update, delete:
          if isEditor(tripId);
      }
    }

    match /tripInvites/{code} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow delete: if signedIn()
        && resource.data.createdBy
          == request.auth.uid;
    }
  }
}
